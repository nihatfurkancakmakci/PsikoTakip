generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  GUEST
  CLIENT
  PSYCHOLOGIST
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum SessionType {
  IN_PERSON
  ONLINE
}

enum PsychologistApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  ACCESS_DENIED
  APPROVE
  REJECT
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  role          Role     @default(CLIENT)
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  verifyToken   String?
  resetToken    String?
  resetTokenExp DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens  RefreshToken[]
  psychologist   Psychologist?
  client         Client?
  admin          AdminProfile?
  notifications  Notification[]
  auditLogs      AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Psychologist {
  id                  String                     @id @default(uuid())
  userId              String                     @unique
  specializations     String[]
  biography           String?
  photoUrl            String?
  educationInfo       String?
  experienceYears     Int?
  certificates        String?
  workingHours        Json
  sessionDurationMin  Int                        @default(50)
  isAcceptingClients  Boolean                    @default(true)
  approvalStatus      PsychologistApprovalStatus @default(PENDING_APPROVAL)
  approvedAt          DateTime?
  approvedById        String?
  rejectionReason     String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  sessionNotes SessionNote[]

  @@map("psychologists")
}

model Client {
  id               String   @id @default(uuid())
  userId           String   @unique
  dateOfBirth      DateTime?
  gender           String?
  emergencyContact String?
  healthNotesEnc   String?
  healthNotesIv    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  testResults  TestResult[]

  @@map("clients")
}

model AdminProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  clinicName     String
  clinicSettings Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model Appointment {
  id               String            @id @default(uuid())
  clientId         String
  psychologistId   String
  startTime        DateTime
  endTime          DateTime
  sessionType      SessionType       @default(IN_PERSON)
  status           AppointmentStatus @default(PENDING)
  videoMeetingUrl  String?
  notes            String?
  cancellationNote String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  sessionNote  SessionNote?
  notifications Notification[]

  @@map("appointments")
}

model SessionNote {
  id                 String   @id @default(uuid())
  appointmentId      String   @unique
  psychologistId     String
  contentEnc         String
  contentIv          String
  emotionalState     String?
  goals              String?
  isSharedWithClient Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@map("session_notes")
}

model PsychologicalTest {
  id                  String   @id @default(uuid())
  name                String
  code                String   @unique
  description         String?
  questions           Json
  scoringAlgorithm    Json
  categoryThresholds  Json
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  testResults TestResult[]

  @@map("psychological_tests")
}

model TestResult {
  id                 String   @id @default(uuid())
  clientId           String
  testId             String
  assignedById       String
  answersEnc         String
  answersIv          String
  totalScore         Float
  scoreCategory      String
  isSharedWithClient Boolean  @default(false)
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  client Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  test   PsychologicalTest @relation(fields: [testId], references: [id])

  @@map("test_results")
}

model Notification {
  id            String              @id @default(uuid())
  userId        String
  appointmentId String?
  type          String
  channel       NotificationChannel @default(EMAIL)
  title         String
  body          String
  isSent        Boolean             @default(false)
  sentAt        DateTime?
  readAt        DateTime?
  createdAt     DateTime            @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  entity     String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  details    Json?
  statusCode Int?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
